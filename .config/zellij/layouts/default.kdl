layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:compact-bar"
    }

    children
  }

  new_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:compact-bar"
    }

    pane {
      name "Terminal"
      command "zsh"
      args "-li"
    }
  }

  tab {
    pane split_direction="vertical" {
      pane size="72" {
        name "AI Agent"
        command "bash"
        args "-c" "if [ -n \"$ZELLIJ_AI_AGENT\" ]; then exec $ZELLIJ_AI_AGENT; else exec claude agents --cwd \"$PWD\"; fi"
      }

      pane {
        pane {
          name "Neovim"
          focus true
          command "bash"
          args "-c" "nvim --listen /tmp/nvim-${ZELLIJ_SESSION_NAME}.sock"
        }

        pane size="25%" {
          name "Terminal"
          command "zsh"
          args "-li"
        }
      }
    }
  }
}
