{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"
    ]
  },
  "imports": {
    "dot-mori/": "https://cdn.jsdelivr.net/gh/ansanloms/dot-mori@v0.1.4/"
  },
  "tasks": {
    "dot-mori": "deno run -A dot-mori/cli.ts",
    "install": "deno task dot-mori --config ./config.yaml",
    "uninstall": "deno task dot-mori --config ./config.yaml --clean",
    "switch": "nix profile upgrade --all --impure",
    "upgrade": "nix flake update --flake \"$HOME/.config/nix\" && nix profile upgrade --all --impure",
    "bump": "deno task bump:playwright-cli && deno task bump:apm",
    "bump:playwright-cli": "deno run --allow-read=.config/nix --allow-write=.config/nix --allow-run=npm,nix .config/nix/playwright-cli/upgrade.ts",
    "bump:apm": "deno run --allow-read=.config/nix --allow-write=.config/nix --allow-run=nix,gh .config/nix/apm/upgrade.ts"
  }
}
