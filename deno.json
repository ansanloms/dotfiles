{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json",
      "AppData/Roaming/CorvusSKK/config.xml",
      "apm.lock.yaml",
      "apm.yml",
      ".agents/skills/"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "plugins": [
      "jsr:@aireone/deno-lint-curly"
    ]
  },
  "imports": {
    "dot-mori/": "https://cdn.jsdelivr.net/gh/ansanloms/dot-mori@0.1.6/",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1.2.1",
    "@std/cli": "jsr:@std/cli@1.0.30",
    "@std/fmt": "jsr:@std/fmt@1.0.10",
    "@std/fs": "jsr:@std/fs@1.0.24",
    "@std/path": "jsr:@std/path@1.1.5",
    "ignore": "npm:ignore@7.0.5"
  },
  "tasks": {
    "dot-mori": {
      "description": "Manage and install dotfiles.",
      "command": "deno run --allow-env=NODE_*,HOME,USERPROFILE --allow-read --allow-write dot-mori/cli.ts"
    },
    "lint": "deno lint && deno fmt --check",
    "fix": "deno lint --fix && deno fmt",
    "check": "deno check ./scripts/* .config/nix/**/*.ts",
    "build": "deno run --allow-read=scripts --allow-write=.local/bin --allow-run=deno scripts/build.ts",
    "install": "deno task dot-mori --config ./config.yaml",
    "uninstall": "deno task dot-mori --config ./config.yaml --clean",
    "switch": {
      "description": "Apply package changes to the profile (packages.nix / *.nix / flake.lock).",
      "command": "nix profile upgrade --all --impure"
    },
    "upgrade": {
      "description": "Update flake inputs (nixpkgs / nix-claude-code / deno).",
      "command": "nix flake update --flake path:.config/nix"
    },
    "remove": {
      "description": "Remove flake inputs.",
      "command": "nix profile remove .config/nix"
    },
    "bump": {
      "description": "Bump self-built nix package versions and hashes (playwright-cli).",
      "command": "deno task bump:*"
    },
    "bump:playwright-cli": "deno run --allow-read=.config/nix --allow-write=.config/nix --allow-run=npm,nix .config/nix/playwright-cli/upgrade.ts"
  }
}
