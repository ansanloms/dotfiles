**/.env

.config/vim/*
!.config/vim/config/
!.config/vim/autoload/
!.config/vim/bitmaps/
!.config/vim/snippets/
!.config/vim/launcher/000-general.yaml
!.config/vim/launcher/001-terminal.yaml
!.config/vim/launcher/002-ai-chat.yaml

.config/git/credentials
.config/git/config.os
.config/git/config.work
.config/git/config.personal

.config/nvim/lua/temp.lua
.config/nvim/lazy-lock.json

.config/alacritty/os.toml

# nix build の成果物（store パスへの symlink）
result

# APM dependencies
apm_modules/

# .local/bin/ 配下は scripts/ から deno bundle で生成する（deno task build）。
# ディレクトリ自体は .gitkeep で残し、生成物はコミットしない。
/.local/bin/*
!/.local/bin/.gitkeep
